@model IEnumerable<Academico.Models.Curso>
@{ ViewData["Title"] = "Cursos"; }
<h2>Cursos</h2>
<p><a asp-action="Create" class="btn btn-primary">Novo Curso</a></p>
<table class="table table-striped">
    <thead><tr><th>Nome</th><th>Carga Horária</th><th>Departamento</th><th></th></tr></thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nome</td>
                <td>@item.CargaHoraria h</td>
                <td>@item.Departamento?.Nome</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Detalhes</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
